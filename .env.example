# --- Database (PostgreSQL) ---
# Local dev: run `npm run db:dev` and copy the printed URL (use 127.0.0.1, not localhost).
# Production: use your hosted Postgres connection string (Supabase, Neon, RDS, ...).
DATABASE_URL="postgres://postgres:postgres@127.0.0.1:51214/template1?sslmode=disable"
SHADOW_DATABASE_URL="postgres://postgres:postgres@127.0.0.1:51215/template1?sslmode=disable"

# --- Admin auth ---
# Secret used to sign admin session tokens. Use a long random string in production.
AUTH_SECRET="generate-a-long-random-string"

# Initial admin account created by `npm run db:seed`
ADMIN_EMAIL=info@vmfholidays.com
ADMIN_NAME="VMF Admin"
ADMIN_PASSWORD="ChangeMe@2026"

# --- Cloudinary (image uploads) ---
# Sign up free at https://cloudinary.com → Dashboard → copy these three values
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# --- Resend (enquiry emails) ---
# Get yours at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where enquiry emails are sent (defaults to info@vmfholidays.com)
ENQUIRY_TO=info@vmfholidays.com

# From address - must be a verified domain in Resend
ENQUIRY_FROM=VMF Holidays <enquiries@vmfholidays.com>
