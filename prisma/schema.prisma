generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MEMBER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUOTED
  WON
  LOST
}

enum LeadSource {
  CONTACT_FORM
  TRIP_WIZARD
  PACKAGE_PAGE
  OTHER
}

enum Region {
  domestic
  international
}

enum TripCategory {
  honeymoon
  family
  adventure
  corporate
  pilgrimage
  college
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String
  passwordHash String
  role         Role          @default(MEMBER)
  active       Boolean       @default(true)
  permissions  String[]      @default([])
  leads        Lead[]        @relation("AssignedLeads")
  notes        LeadNote[]
  activity     ActivityLog[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?
  userName  String
  action    String
  entity    String
  entityId  String?
  detail    String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Lead {
  id           String     @id @default(cuid())
  name         String
  phone        String
  email        String
  source       LeadSource @default(OTHER)
  status       LeadStatus @default(NEW)
  destination  String?
  dates        String?
  travelers    String?
  budget       String?
  tripLength   String?
  contactMode  String?
  contactTime  String?
  interests    String[]
  message      String?
  packageTitle String?
  hotelCategory String?
  mealPlan      String?
  assignedTo   User?      @relation("AssignedLeads", fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedToId String?
  notes        LeadNote[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([status])
  @@index([createdAt])
}

model LeadNote {
  id        String   @id @default(cuid())
  body      String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorId  String?
  createdAt DateTime @default(now())
}

model Destination {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  country   String
  region    Region
  heroImage String
  fromPrice Int
  blurb     String
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Package {
  id              String       @id @default(cuid())
  slug            String       @unique
  title           String
  destination     String
  destinationSlug String
  category        TripCategory
  duration        String
  nights          Int
  heroImage       String
  gallery         String[]
  hotel           String?
  hotelImage      String?
  fromPrice       Int
  highlights      String[]
  inclusions      String[]
  exclusions      String[]
  itinerary       Json         @default("[]")
  featured        Boolean      @default(false)
  badge           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([destinationSlug])
  @@index([category])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  location  String
  trip      String
  rating    Int      @default(5)
  quote     String
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String
  content     String
  coverImage  String?
  author      String    @default("VMF Holidays")
  tags        String[]  @default([])
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, publishedAt])
}

model Offer {
  id          String    @id @default(cuid())
  title       String
  description String?
  image       String
  ctaLabel    String?
  ctaHref     String?
  badge       String?
  published   Boolean   @default(true)
  sortOrder   Int       @default(0)
  endsAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, sortOrder])
}

model GalleryPhoto {
  id        String   @id @default(cuid())
  image     String
  caption   String?
  location  String?
  published Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, sortOrder])
}
