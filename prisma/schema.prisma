generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MEMBER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUOTED
  WON
  LOST
}

enum LeadSource {
  CONTACT_FORM
  TRIP_WIZARD
  PACKAGE_PAGE
  OTHER
}

enum Region {
  domestic
  international
}

enum TripCategory {
  honeymoon
  family
  adventure
  corporate
  pilgrimage
  college
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String
  passwordHash String
  role         Role          @default(MEMBER)
  active       Boolean       @default(true)
  permissions  String[]      @default([])
  leads        Lead[]        @relation("AssignedLeads")
  notes        LeadNote[]
  activity     ActivityLog[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?
  userName  String
  action    String
  entity    String
  entityId  String?
  detail    String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Lead {
  id           String     @id @default(cuid())
  name         String
  phone        String
  email        String
  source       LeadSource @default(OTHER)
  status       LeadStatus @default(NEW)
  destination  String?
  dates        String?
  travelers    String?
  budget       String?
  tripLength   String?
  contactMode  String?
  contactTime  String?
  interests    String[]
  message      String?
  packageTitle String?
  hotelCategory String?
  mealPlan      String?
  referralCode String?    // Travellers Club code the enquiry was attributed to
  assignedTo   User?      @relation("AssignedLeads", fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedToId String?
  notes        LeadNote[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([status])
  @@index([createdAt])
}

model LeadNote {
  id        String   @id @default(cuid())
  body      String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorId  String?
  createdAt DateTime @default(now())
}

model Destination {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  country   String
  region    Region
  heroImage String
  fromPrice Int
  blurb     String
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Package {
  id              String       @id @default(cuid())
  slug            String       @unique
  title           String
  destination     String
  destinationSlug String
  category        TripCategory
  duration        String
  nights          Int
  heroImage       String
  gallery         String[]
  hotel           String?
  hotelImage      String?
  fromPrice       Int
  priceOnRequest  Boolean      @default(false)
  highlights      String[]
  inclusions      String[]
  exclusions      String[]
  itinerary       Json         @default("[]")
  featured        Boolean      @default(false)
  badge           String?
  // Travellers Club gate (WI-6): STANDARD_RETAIL earns + redeems; LAUNCHED_GROUP excluded on both sides.
  productClass    ProductClass @default(STANDARD_RETAIL)
  travelStyles    String[]     @default([]) // WI-7 style tags for recommendations
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([destinationSlug])
  @@index([category])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  location  String
  trip      String
  rating    Int      @default(5)
  quote     String
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String
  content     String
  coverImage  String?
  author      String    @default("VMF Holidays")
  tags        String[]  @default([])
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, publishedAt])
}

model Offer {
  id          String    @id @default(cuid())
  title       String
  description String?
  image       String
  ctaLabel    String?
  ctaHref     String?
  badge       String?
  published   Boolean   @default(true)
  sortOrder   Int       @default(0)
  endsAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, sortOrder])
}

model GalleryPhoto {
  id        String   @id @default(cuid())
  image     String
  caption   String?
  location  String?
  published Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, sortOrder])
}

// Trip Builder geography — countries, their cities/places and each place's
// activities. Editable from the admin CMS; the public Trip Builder falls back to
// the bundled lib/data/geography.ts when these tables are empty or not migrated.
model GeoCountry {
  id        String     @id @default(cuid())
  code      String     @unique
  name      String
  flag      String     @default("")
  continent String
  region    Region
  heroImage String
  sortOrder Int        @default(0)
  places    GeoPlace[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model GeoPlace {
  id              String     @id @default(cuid())
  country         GeoCountry @relation(fields: [countryId], references: [id], onDelete: Cascade)
  countryId       String
  slug            String
  name            String
  destinationSlug String?
  image           String?
  lat             Float?
  lng             Float?
  activities      String[]   @default([])
  sortOrder       Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([countryId, slug])
  @@index([countryId])
}

// ─────────────────────────────────────────────────────────────────────────────
// VMF Holidays Travellers Club — referral program (v5 spec: locked economics,
// anti-fraud, tiers, redemption, engagement, badges). Two-sided travel-credit
// referrals + a WhatsApp community. Config lives in lib/referral.ts. Apply schema
// changes with `npm run db:push` (regenerates the client), then verify on preview.
// ─────────────────────────────────────────────────────────────────────────────

enum MemberTier {
  EXPLORER
  VOYAGER
  NAVIGATOR
  AMBASSADOR
}

enum ReferralStatus {
  PENDING // friend referred, not yet enquired
  ENQUIRED // friend submitted an enquiry
  BOOKED // friend completed a paid booking
  WELCOME_PAID // friend travelled + got their welcome, but referrer-reward gate not met
  REWARDED // referrer credited (full ₹25k+ gate passed)
  REJECTED_MARGIN // auto-rejected by the margin guard (WI-14a); no credit issued
  NEEDS_DATA // margin/booking value missing — awaiting ops (WI-14a)
  EXPIRED // lapsed without travel (WI-12 sweep)
  REJECTED // disqualified (self-referral / fraud)
}

enum CreditReason {
  JOIN_BONUS // ₹250 granted on signup (WI-5)
  REFERRAL_REWARD // earned for referring a friend who completed travel
  WELCOME_BONUS // friend's first-trip welcome credit
  ENGAGEMENT // light-action engagement credit (WI-13)
  REDEMPTION // spent against a booking
  ADJUSTMENT // manual admin correction
  EXPIRY // credit expired
}

enum RedemptionStatus {
  PENDING
  APPROVED
  APPLIED
  REJECTED
  REVERSED // trip cancelled/refunded — credit restored (WI-18B)
}

enum EngagementStatus {
  PENDING
  APPROVED
  REJECTED
}

// Travellers Club earn/spend gate (WI-6). STANDARD_RETAIL (fixed template + Build
// My Trip) earns and redeems; LAUNCHED_GROUP (college/group/budget) is excluded.
enum ProductClass {
  STANDARD_RETAIL
  LAUNCHED_GROUP
}

model Member {
  id               String        @id @default(cuid())
  name             String
  phone            String        @unique
  email            String        @unique
  passwordHash     String
  referralCode     String        @unique
  tier             MemberTier    @default(EXPLORER)
  creditBalance    Int           @default(0) // travel credit balance, INR
  completedTrips   Int           @default(0) // completed VMF trips (drives tier + badges)
  travelStyles     String[]      @default([]) // WI-7 style keys, aligned to WhatsApp segments
  ambassadorSpotlightConsent Boolean @default(false) // WI-13: OK to feature at Ambassador tier
  whatsappJoinedAt DateTime?
  firstBookingAt   DateTime? // set on their first booking (gates the welcome bonus)
  lastLoginAt      DateTime?
  lastActivityAt   DateTime? // bumped on any earn/redeem/login/trip; drives 24-month expiry
  active           Boolean       @default(true)
  // Self-relation: which member referred this member (if any).
  referredBy       Member?       @relation("MemberReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referredById     String?
  referredMembers  Member[]      @relation("MemberReferrals")
  // Referral events where this member is the referrer / the referred friend.
  referrals        Referral[]    @relation("ReferralReferrer")
  refereeReferrals Referral[]    @relation("ReferralReferee")
  credits          CreditEntry[]
  redemptionRequests RedemptionRequest[]
  badges           MemberBadge[]
  engagementClaims EngagementClaim[]
  tripDraft        TripDraft?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([referredById])
}

// A logged-in member's saved, in-progress Trip Builder session (WI: save & resume).
// One draft per member; the wizard state is stored as opaque JSON and restored on
// return. Cleared when the member submits or starts fresh.
model TripDraft {
  id        String   @id @default(cuid())
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId  String   @unique
  state     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Referral {
  id                String         @id @default(cuid())
  referrer          Member         @relation("ReferralReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referrerId        String
  // The referred friend's Member account, set once they sign up (WI-16 "Joined").
  refereeMember     Member?        @relation("ReferralReferee", fields: [refereeMemberId], references: [id], onDelete: SetNull)
  refereeMemberId   String?
  refereeName       String?
  refereePhone      String?
  status            ReferralStatus @default(PENDING)
  bookingValue      Int? // INR, set when the friend books
  tripMargin        Int? // INR, admin-entered at trip completion (margin guard, WI-4/WI-14)
  travelCompletedAt DateTime? // set when the friend completes travel (gates the reward)
  rewardEligible    Boolean        @default(false)
  rewardAmount      Int? // INR credited to the referrer on reward
  leadId            String? // attribution to a Lead (loose link, no FK)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([referrerId])
  @@index([refereeMemberId])
  @@index([status])
}

model CreditEntry {
  id         String       @id @default(cuid())
  member     Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId   String
  amount     Int // +earned / -redeemed, INR
  reason     CreditReason
  note       String?
  approvedBy String? // admin id, or 'SYSTEM_AUTO' for auto-decisions (WI-14)
  createdAt  DateTime     @default(now())

  @@index([memberId])
}

model RedemptionRequest {
  id          String           @id @default(cuid())
  member      Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId    String
  amount      Int
  packageNote String?
  tripType    String? // "DOMESTIC" | "INTERNATIONAL"
  status      RedemptionStatus @default(PENDING)
  leadId      String?
  resolvedBy  String? // admin id, or 'SYSTEM_AUTO'
  createdAt   DateTime         @default(now())
  resolvedAt  DateTime?

  @@index([memberId])
  @@index([status])
}

model MemberBadge {
  id       String   @id @default(cuid())
  member   Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId String
  key      String
  earnedAt DateTime @default(now())

  @@unique([memberId, key])
  @@index([memberId])
}

model EngagementClaim {
  id         String           @id @default(cuid())
  member     Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId   String
  taskKey    String
  credit     Int
  status     EngagementStatus @default(PENDING)
  approvedBy String?
  // Admin's reason when a claim is rejected — surfaced back to the member.
  reviewNote String?
  createdAt  DateTime         @default(now())
  approvedAt DateTime?

  @@unique([memberId, taskKey])
  @@index([memberId])
  @@index([status])
}

// Audit trail for the non-member "apply ₹1,000 welcome as a booking discount"
// action (WI-14c). Written in the same transaction as applying the discount, so
// the off-ledger welcome can never go untracked.
model WelcomeDiscountLog {
  id           String   @id @default(cuid())
  bookingId    String?
  leadId       String?
  refereeName  String?
  refereePhone String?
  referrerId   String?
  amount       Int
  note         String?
  createdAt    DateTime @default(now())

  @@index([referrerId])
}
