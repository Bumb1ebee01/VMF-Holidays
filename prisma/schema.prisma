generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MEMBER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUOTED
  WON
  LOST
}

enum LeadSource {
  CONTACT_FORM
  TRIP_WIZARD
  PACKAGE_PAGE
  OTHER
}

enum Region {
  domestic
  international
}

enum TripCategory {
  honeymoon
  family
  adventure
  corporate
  pilgrimage
  college
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String
  passwordHash String
  role         Role          @default(MEMBER)
  active       Boolean       @default(true)
  permissions  String[]      @default([])
  leads        Lead[]        @relation("AssignedLeads")
  notes        LeadNote[]
  activity     ActivityLog[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?
  userName  String
  action    String
  entity    String
  entityId  String?
  detail    String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Lead {
  id           String     @id @default(cuid())
  name         String
  phone        String
  email        String
  source       LeadSource @default(OTHER)
  status       LeadStatus @default(NEW)
  destination  String?
  dates        String?
  travelers    String?
  budget       String?
  tripLength   String?
  contactMode  String?
  contactTime  String?
  interests    String[]
  message      String?
  packageTitle String?
  hotelCategory String?
  mealPlan      String?
  referralCode String?    // Travellers Club code the enquiry was attributed to
  assignedTo   User?      @relation("AssignedLeads", fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedToId String?
  notes        LeadNote[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([status])
  @@index([createdAt])
}

model LeadNote {
  id        String   @id @default(cuid())
  body      String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorId  String?
  createdAt DateTime @default(now())
}

model Destination {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  country   String
  region    Region
  heroImage String
  fromPrice Int
  blurb     String
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Package {
  id              String       @id @default(cuid())
  slug            String       @unique
  title           String
  destination     String
  destinationSlug String
  category        TripCategory
  duration        String
  nights          Int
  heroImage       String
  gallery         String[]
  hotel           String?
  hotelImage      String?
  fromPrice       Int
  priceOnRequest  Boolean      @default(false)
  highlights      String[]
  inclusions      String[]
  exclusions      String[]
  itinerary       Json         @default("[]")
  featured        Boolean      @default(false)
  badge           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([destinationSlug])
  @@index([category])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  location  String
  trip      String
  rating    Int      @default(5)
  quote     String
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String
  content     String
  coverImage  String?
  author      String    @default("VMF Holidays")
  tags        String[]  @default([])
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, publishedAt])
}

model Offer {
  id          String    @id @default(cuid())
  title       String
  description String?
  image       String
  ctaLabel    String?
  ctaHref     String?
  badge       String?
  published   Boolean   @default(true)
  sortOrder   Int       @default(0)
  endsAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, sortOrder])
}

model GalleryPhoto {
  id        String   @id @default(cuid())
  image     String
  caption   String?
  location  String?
  published Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, sortOrder])
}

// Trip Builder geography — countries, their cities/places and each place's
// activities. Editable from the admin CMS; the public Trip Builder falls back to
// the bundled lib/data/geography.ts when these tables are empty or not migrated.
model GeoCountry {
  id        String     @id @default(cuid())
  code      String     @unique
  name      String
  flag      String     @default("")
  continent String
  region    Region
  heroImage String
  sortOrder Int        @default(0)
  places    GeoPlace[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model GeoPlace {
  id              String     @id @default(cuid())
  country         GeoCountry @relation(fields: [countryId], references: [id], onDelete: Cascade)
  countryId       String
  slug            String
  name            String
  destinationSlug String?
  image           String?
  lat             Float?
  lng             Float?
  activities      String[]   @default([])
  sortOrder       Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([countryId, slug])
  @@index([countryId])
}

// ─────────────────────────────────────────────────────────────────────────────
// VMF Holidays Travellers Club — referral program (see docs/REFERRAL-PROGRAM.md).
// Two-sided travel-credit referrals + a WhatsApp community. These models define
// the schema; the public/admin/API code is built in a follow-up phase. Apply with
// `npm run db:push`. Nothing queries these tables yet, so they're inert until then.
// ─────────────────────────────────────────────────────────────────────────────

enum MemberTier {
  EXPLORER
  VOYAGER
  GLOBETROTTER
  AMBASSADOR
}

enum ReferralStatus {
  PENDING // friend referred, not yet enquired
  ENQUIRED // friend submitted an enquiry
  BOOKED // friend completed a paid booking (reward due)
  REWARDED // referrer credited
  EXPIRED // lapsed without booking
  REJECTED // disqualified (self-referral / fraud)
}

enum CreditReason {
  REFERRAL_REWARD // earned for referring a booked friend
  WELCOME_BONUS // friend's first-trip welcome credit
  REDEMPTION // spent against a booking
  ADJUSTMENT // manual admin correction
  EXPIRY // credit expired
}

model Member {
  id               String        @id @default(cuid())
  name             String
  phone            String        @unique
  email            String?
  referralCode     String        @unique
  tier             MemberTier    @default(EXPLORER)
  creditBalance    Int           @default(0) // travel credit balance, INR
  whatsappJoinedAt DateTime?
  active           Boolean       @default(true)
  // Self-relation: which member referred this member (if any).
  referredBy       Member?       @relation("MemberReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referredById     String?
  referredMembers  Member[]      @relation("MemberReferrals")
  // Referral events where this member is the referrer.
  referrals        Referral[]
  credits          CreditEntry[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([referredById])
}

model Referral {
  id           String         @id @default(cuid())
  referrer     Member         @relation(fields: [referrerId], references: [id], onDelete: Cascade)
  referrerId   String
  refereeName  String?
  refereePhone String?
  status       ReferralStatus @default(PENDING)
  bookingValue Int? // INR, set when the friend books
  rewardAmount Int? // INR credited to the referrer on reward
  leadId       String? // attribution to a Lead (loose link, no FK)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([referrerId])
  @@index([status])
}

model CreditEntry {
  id        String       @id @default(cuid())
  member    Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId  String
  amount    Int // +earned / -redeemed, INR
  reason    CreditReason
  note      String?
  createdAt DateTime     @default(now())

  @@index([memberId])
}
